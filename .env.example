# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# === Firebase ===
# Option 1 (local): Path to credentials JSON file
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Option 2 (Railway/cloud): Base64-encoded JSON string (use this on Railway)
# FIREBASE_CREDENTIALS_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
# Database ID (your Firestore database name)
FIREBASE_DATABASE_ID=pussy

# === Encryption ===
ENCRYPTION_KEY=your-fernet-key-base64

# === Default ElevenLabs Voice ID ===
ELEVENLABS_DEFAULT_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# === Ollama Cloud ===
OLLAMA_HOST=https://ollama.com

# === Bot Settings ===
MAX_CHAT_HISTORY=20
TYPING_DELAY_MIN=1.0
TYPING_DELAY_MAX=3.0
